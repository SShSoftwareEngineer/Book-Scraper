# === Project Settings ===
# Base URL for parsing
BASE_URL=
# Categories URL
CAT_SUBCAT_URL=
# Number of parser threads
PARSERS_COUNT=
# Maximum size of the HTML queue
HTML_QUEUE_MAXSIZE=
# Maximum size of the result queue
RESULT_QUEUE_MAXSIZE=

# === Database Settings ===
# Database name
DB_NAME=
# Database host
HOST=
# Database port
PORT=
# User name
USER=
# User password
PASSWORD=
# Batch buffer size
BATCH_SIZE=

# === Parsing Delays & Timeouts ===
# Minimum delay before request HTTP in seconds
MIN_DELAY=
# Maximum delay before request HTTP in seconds
MAX_DELAY=
# Delay between page requests in seconds
PAGE_DELAY=
# ClientTimeout total timeout in seconds
TIMEOUT_TOTAL=
# ClientTimeout connect timeout in seconds
TIMEOUT_CONNECT=
# ClientTimeout sock_read timeout in seconds
TIMEOUT_SOCK_READ=
# Maximum number of concurrent HTTP requests
MAX_CONCURRENT_REQUESTS=
# Maximum pages per category for search, 0 or None for unlimited
MAX_PAGE_PER_CATEGORY=

# === Filters ===
# Categories to parse, separated by commas
TARGET_CATEGORIES=